SEARCH_API_PORT=4001
SEARCH_API_HOST=0.0.0.0
NEXT_PUBLIC_SEARCH_API_URL=http://localhost:4001

# Database — PostgreSQL (Railway recommended) or SQLite (offline local only)
#
# Railway PostgreSQL (public proxy for local dev; use plugin reference on Railway):
# DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway?sslmode=require"
#
# SQLite example (legacy local; schema in repo targets PostgreSQL):
# DATABASE_URL="file:./prisma/dev.db"
DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway?sslmode=require"

# Session lifetime for auth tokens (hours)
SESSION_TTL_HOURS=24

# Runtime mode and API hardening
NODE_ENV=development
ENFORCE_HTTPS=false

# First-run setup (set ALLOW_SETUP=false to disable the setup wizard)
APP_NAME=Retail Discovery Platform
ALLOW_SETUP=true

# Rate limiting (in-memory, per-process)
RATE_LIMIT_AUTH_LOGIN_LIMIT=5
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_ADMIN_MUTATION_LIMIT=60
RATE_LIMIT_ADMIN_MUTATION_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_READ_LIMIT=300
RATE_LIMIT_ADMIN_READ_WINDOW_SECONDS=60

# Railway sets PORT automatically and the API binds to PORT when it is present.
# Do not set SEARCH_API_PORT on Railway unless you know you need a fixed local port.
#
# Required on admin Railway service (runtime, no rebuild needed for URL changes):
# SEARCH_API_URL=https://search-api-production.up.railway.app
#
# Required on storefront Railway service (must be set before build):
# NEXT_PUBLIC_SEARCH_API_URL=https://search-api-production.up.railway.app
