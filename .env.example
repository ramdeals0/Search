SEARCH_API_PORT=4001
SEARCH_API_HOST=0.0.0.0
NEXT_PUBLIC_SEARCH_API_URL=http://localhost:4001

# Railway sets PORT automatically. SEARCH_API_PORT falls back to PORT when unset.
# After deploy, set this on admin/Vercel to your Railway public URL, e.g.:
# NEXT_PUBLIC_SEARCH_API_URL=https://search-api-production.up.railway.app
