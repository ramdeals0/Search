generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  merchandiser
  reviewer
  approver
  release_manager
  developer
  admin
}

enum AccessRequestStatus {
  pending
  approved
  denied
  cancelled
}

enum AccessReviewStatus {
  open
  completed
}

enum JitAccessStatus {
  pending
  active
  denied
  expired
  cancelled
  revoked
}

enum ExportJobStatus {
  generated
  failed
}

enum ExportFormat {
  json
  csv
}

enum ExportTargetType {
  audit_trail
  approvals
  access_reviews
  security_timeline
  audit_review_findings
  soc2_audit_package
  audit_hash_chain_report
  api_usage_meters
}

enum ScheduledReleaseType {
  promote_snapshot
  rollback_snapshot
}

enum ScheduledReleaseStatus {
  pending
  executed
  cancelled
  failed
}

enum RuleDraftStatus {
  pending_review
  approved
  rejected
  applied
}

model User {
  id          String    @id
  email       String    @unique
  name        String
  role        UserRole
  active      Boolean   @default(true)
  password    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  sessions    Session[]

  @@index([role])
  @@index([active])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model AuditTrailEntry {
  id            String   @id
  timestamp     DateTime @default(now())
  actorId       String
  actorLabel    String
  actionType    String
  entityType    String
  entityId      String?
  entityLabel   String?
  outcome       String
  summary       String
  metadata      Json?
  hashChainPrev String?

  @@index([timestamp])
  @@index([actionType])
  @@index([entityType])
  @@index([outcome])
  @@index([actorId])
}

model ApprovalRequest {
  id                    String   @id
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  status                String
  sourceEnvironment     String
  targetEnvironment     String
  snapshotId            String?
  snapshotName          String?
  requestedBy           Json
  approvedBy            Json?
  rejectedBy            Json?
  reason                String
  decisionNote          String?
  linkedExperimentId    String?
  assignedReviewerIds   Json?
  decisions             Json?
  requiredApprovalCount Int?
  executedBy            Json?

  @@index([status])
  @@index([createdAt])
  @@index([snapshotId])
}

model AccessRequest {
  id               String              @id
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  requesterUserId  String
  requesterEmail   String
  requesterName    String
  requestedRole    UserRole
  justification    String
  status           AccessRequestStatus
  reviewerUserId   String?
  reviewerName     String?
  reviewerNote     String?

  @@index([status])
  @@index([requesterUserId])
  @@index([createdAt])
}

model AccessReviewRun {
  id              String             @id
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdByUserId String
  createdByName   String
  status          AccessReviewStatus
  scopeRoles      Json
  completedAt     DateTime?
  summary         Json?
  items           AccessReviewItem[]

  @@index([status])
  @@index([createdAt])
}

model AccessReviewItem {
  id                String          @id @default(cuid())
  runId             String
  run               AccessReviewRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId            String
  userEmail         String
  userName          String
  currentRole       UserRole
  active            Boolean
  lastLoginAt       DateTime?
  recommendedAction String?
  note              String?

  @@index([runId])
  @@index([userId])
}

model JitElevationRequest {
  id                       String          @id
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  requesterUserId          String
  requesterEmail           String
  requesterName            String
  baseRole                 UserRole
  requestedRole            UserRole
  justification            String
  requestedDurationMinutes Int
  status                   JitAccessStatus
  approvedByUserId         String?
  approvedByName           String?
  reviewerNote             String?
  activatedAt              DateTime?
  expiresAt                DateTime?
  revokedAt                DateTime?

  @@index([status])
  @@index([requesterUserId])
  @@index([expiresAt])
  @@index([createdAt])
}

model CollaborationComment {
  id              String   @id
  targetType      String
  targetId        String
  author          Json
  message         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String
  parentCommentId String?
  tags            Json?

  @@index([targetType, targetId])
  @@index([createdAt])
}

model CollaborationAnnotation {
  id          String   @id
  targetType  String
  targetId    String
  author      Json
  anchorLabel String
  note        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        Json?

  @@index([targetType, targetId])
  @@index([createdAt])
}

model Notification {
  id                       String   @id
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  type                     String
  title                    String
  message                  String
  relatedApprovalRequestId String?
  recipientActorId         String?
  read                     Boolean  @default(false)

  @@index([read])
  @@index([recipientActorId])
  @@index([createdAt])
  @@index([relatedApprovalRequestId])
}

model ExportJob {
  id               String           @id
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdByUserId  String
  createdByName    String
  targetType       ExportTargetType
  format           ExportFormat
  status           ExportJobStatus
  filters          Json?
  fileName         String?
  recordCount      Int?
  errorMessage     String?

  @@index([createdAt])
  @@index([targetType])
  @@index([status])
  @@index([createdByUserId])
}

model WebhookEndpoint {
  id                 String   @id
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  name               String
  url                String
  active             Boolean  @default(true)
  subscribedEvents   Json
  secret             String?
  lastDeliveryAt     DateTime?
  lastDeliveryStatus String?
  deliveries         WebhookDeliveryLog[]

  @@index([active])
  @@index([createdAt])
}

model WebhookDeliveryLog {
  id                 String          @id
  createdAt          DateTime        @default(now())
  endpointId         String
  endpoint           WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType          String
  status             String
  responseStatusCode Int?
  errorMessage       String?
  attemptNumber      Int

  @@index([endpointId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

enum BootstrapStatusEnum {
  not_started
  admin_created
  security_configured
  platform_configured
  completed
}

model BootstrapState {
  id                       String              @id
  status                   BootstrapStatusEnum @default(not_started)
  initializedAt            DateTime?
  initializedByUserId      String?
  initializedByEmail       String?
  instanceName             String?
  firstAdminEmail          String?
  securityDefaultsApplied  Boolean             @default(false)
  governanceDefaultsApplied Boolean            @default(false)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Catalog {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  slug        String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([active])
}

model Brand {
  id        String    @id
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([name])
}

model Category {
  id          String    @id
  department  String
  subcategory String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@unique([department, subcategory])
  @@index([department])
}

model Product {
  id          String   @id
  sku         String   @unique
  title       String
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  catalogId   String   @default("default")
  catalog     Catalog  @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  description String
  price       Float
  inventory   Int
  inStock     Boolean
  imageUrl    String?
  attributes  Json
  createdAt   DateTime
  updatedAt   DateTime

  @@index([brandId])
  @@index([categoryId])
  @@index([catalogId])
  @@index([inStock])
  @@index([title])
  @@index([updatedAt])
}

model ApiKey {
  id                 String    @id @default(cuid())
  name               String
  keyHash            String    @unique
  keyPrefix          String
  tenantId           String    @default("default")
  ownerUserId        String?
  scopes             String[]  @default(["search:read", "browse:read", "events:write"])
  enabled            Boolean   @default(true)
  rateLimitPerMinute Int?
  lastUsedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId])
  @@index([ownerUserId])
  @@index([enabled])
}

model SearchEvent {
  id          String   @id @default(cuid())
  query       String
  normalizedQuery String
  resultCount Int
  tenantId    String   @default("default")
  apiKeyId    String?
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([normalizedQuery])
  @@index([resultCount])
  @@index([createdAt])
}

model SearchClickEvent {
  id          String   @id @default(cuid())
  query       String
  normalizedQuery String
  productId   String
  productTitle String
  position    Int?
  tenantId    String   @default("default")
  apiKeyId    String?
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([normalizedQuery])
  @@index([createdAt])
}

model ScheduledRelease {
  id                   String                 @id @default(cuid())
  type                 ScheduledReleaseType
  status               ScheduledReleaseStatus @default(pending)
  snapshotId           String
  reason               String
  scheduledAt          DateTime
  executedAt           DateTime?
  linkedExperimentId   String?
  approvalRequestId    String?
  errorMessage         String?
  createdByUserId      String?
  createdByEmail       String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([status, scheduledAt])
  @@index([snapshotId])
}

model RuleDraft {
  id                String          @id @default(cuid())
  query             String
  status            RuleDraftStatus @default(pending_review)
  suggestedRule     Json
  rationale         String?
  source            String          @default("llm")
  createdByUserId   String?
  approvalRequestId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status])
  @@index([query])
}

model ApiUsageMeter {
  id           String   @id @default(cuid())
  apiKeyId     String
  tenantId     String   @default("default")
  route        String
  windowStart  DateTime
  requestCount Int      @default(0)

  @@unique([apiKeyId, route, windowStart])
  @@index([tenantId])
  @@index([windowStart])
}

model EvaluationQuerySet {
  id          String             @id
  name        String
  description String?
  queries     Json
  createdAt   DateTime           @default(now())
  experiments ExperimentRecord[]
}

model ExperimentRecord {
  id                    String   @id
  name                  String
  description           String?
  status                String
  baselineSnapshotId    String
  candidateSnapshotId   String
  querySetId            String
  querySet              EvaluationQuerySet @relation(fields: [querySetId], references: [id], onDelete: Cascade)
  candidateLlmOverrides Json?
  candidateAiConfig     Json?
  lastRunAt             DateTime?
  onlineEnabled         Boolean  @default(false)
  onlineTrafficPercent  Int      @default(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  lastRun               ExperimentRunRecord?
  scorecard             ExperimentScorecardRecord?
  decision              ExperimentDecisionRecord?

  @@index([status])
  @@index([querySetId])
  @@index([onlineEnabled])
}

model ExperimentRunRecord {
  experimentId String           @id
  experiment   ExperimentRecord @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  payload      Json
  runAt        DateTime
}

model ExperimentScorecardRecord {
  experimentId String           @id
  experiment   ExperimentRecord @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  payload      Json
  generatedAt  DateTime         @default(now())
}

model ExperimentDecisionRecord {
  experimentId String           @id
  experiment   ExperimentRecord @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  payload      Json
  decidedAt    DateTime         @default(now())
}

model SearchContentModule {
  id          String   @id @default(cuid())
  name        String
  active      Boolean  @default(true)
  environment String   @default("staging")
  moduleType  String
  priority    Int      @default(100)
  condition   Json
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([environment, active])
}

model ProductEmbedding {
  productId   String   @id
  embedding   Json
  textHash    String?
  model       String   @default("mock-hash-v1")
  provider    String   @default("mock")
  dimensions  Int      @default(64)
  updatedAt   DateTime @updatedAt
}

model EmbeddingJob {
  id                String   @id @default(cuid())
  status            String   @default("queued")
  jobType           String   @default("backfill")
  totalProducts     Int      @default(0)
  processedProducts Int      @default(0)
  failedProducts    Int      @default(0)
  model             String   @default("mock-hash-v1")
  provider          String   @default("mock")
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, createdAt])
}

model ShopperProfile {
  sessionId  String   @id
  tenantId   String   @default("default")
  affinities Json
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

model CommerceEvent {
  id          String   @id @default(cuid())
  type        String
  sessionId   String?
  tenantId    String   @default("default")
  query       String?
  productId   String?
  amountCents Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([sessionId])
  @@index([tenantId])
}
